{
  "description": "converts building layer to fill-extrusion with mapped paint and layout properties",
  "input": {
    "version": 8,
    "sources": {
      "s": {
        "type": "vector",
        "url": "mapbox://test"
      }
    },
    "layers": [
      {
        "id": "buildings",
        "type": "building",
        "source": "s",
        "source-layer": "building",
        "paint": {
          "building-color": "#aaa",
          "building-opacity": 0.8,
          "building-emissive-strength": 0.5
        },
        "layout": {
          "visibility": "visible",
          "building-height": ["get", "height"],
          "building-base": ["get", "min_height"],
          "building-roof-shape": "flat"
        }
      }
    ]
  },
  "expected": {
    "version": 8,
    "sources": {
      "s": {
        "type": "vector",
        "url": "https://api.mapbox.com/v4/test.json"
      }
    },
    "layers": [
      {
        "id": "buildings",
        "type": "fill-extrusion",
        "source": "s",
        "source-layer": "building",
        "paint": {
          "fill-extrusion-color": "#aaa",
          "fill-extrusion-opacity": 0.8,
          "fill-extrusion-height": ["get", "height"],
          "fill-extrusion-base": ["get", "min_height"]
        },
        "layout": {
          "visibility": "visible"
        }
      }
    ]
  }
}
